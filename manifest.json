{
  "manifest_version": 3,
  "name": "Research Collector",
  "version": "1.0",
  "description": "Save snippets to Notion or Google Drive in one click.",
  "permissions": ["contextMenus", "storage", "scripting", "identity"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "index.html"
}
