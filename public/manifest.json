{
  "manifest_version": 3,
  "name": "Research Collector",
  "version": "1.0.0",
  "description": "Save highlighted research snippets directly to Notion or Google Drive.",

  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab",
    "identity",
    "notifications"
  ],
  "host_permissions": ["*://*/*"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "chrome_url_overrides": {
    "newtab": "onboarding.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
